# Feature Execution Checkpoint
# Written by feature-execution skill after each wave.
# Read by SessionStart hook (config.toml) for context recovery.
# Read by feature-execution Phase 1 to detect resume scenario.

skill: feature-execution
feature: {feature}
feature_dir: work/{feature}
execution_plan: work/{feature}/logs/execution-plan.md
last_completed_wave: 0
total_waves: 0

# Format: task_number: status (planned | in_progress | done)
# Example:
#   1: done
#   2: done
#   3: in_progress
#   4: planned
tasks: {}

next_wave: 1

# Session tracking (from session-plan.md, generated by task-decomposition)
# If session-plan.md does not exist — all waves are treated as one session.
current_session: 1
total_sessions: 0
session_plan: work/{feature}/logs/session-plan.md
